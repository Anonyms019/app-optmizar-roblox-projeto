from utils.cleanup import clear_temp_files
from utils.settings import optimize_graphics
from utils.monitor import monitor_performance

def main():
    print("Iniciando Roblox Optimizer...")
    
    # Limpar arquivos temporários
    clear_temp_files()
    
    # Ajustar configurações gráficas
    optimize_graphics()
    
    # Monitorar desempenho
    monitor_performance()

if __name__ == "__main__":
    main()
